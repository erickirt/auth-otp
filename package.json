{
  "name": "@perseidesjs/auth-otp",
  "version": "2.1.1",
  "description": "An OTP Auth Provider for Medusa 2.x",
  "author": "adevinwild (https://perseides.org)",
  "types": "./.medusa/server/src/types/index.d.ts",
  "files": [
    ".medusa/server",
    ".github/assets",
    "CHANGELOG.md"
  ],
  "keywords": [
    "medusa-plugin-auth",
    "medusa-v2"
  ],
  "license": "MIT",
  "exports": {
    "./package.json": "./package.json",
    "./workflows": "./.medusa/server/src/workflows/index.js",
    "./.medusa/server/src/modules/*": "./.medusa/server/src/modules/*/index.js",
    "./providers/*": "./.medusa/server/src/providers/*/index.js",
    "./admin": {
      "import": "./.medusa/server/src/admin/index.mjs",
      "require": "./.medusa/server/src/admin/index.js",
      "default": "./.medusa/server/src/admin/index.js"
    },
    "./types": {
      "types": "./.medusa/server/src/types/index.d.ts",
      "default": "./.medusa/server/src/types/index.js"
    },
    "./*": "./.medusa/server/src/*.js"
  },
  "scripts": {
    "generate-types": "tsc -p tsconfig.index.json",
    "build": "medusa plugin:build && npm run generate-types",
    "dev": "medusa plugin:develop",
    "prepublishOnly": "npm run build",
    "release": "yarn build && changeset publish",
    "test:integration:http": "TEST_TYPE=integration:http NODE_OPTIONS=--experimental-vm-modules jest --silent=false --runInBand --forceExit",
    "test:integration:providers": "TEST_TYPE=integration:providers NODE_OPTIONS=--experimental-vm-modules jest --silent --runInBand --forceExit",
    "test:unit": "TEST_TYPE=unit NODE_OPTIONS=--experimental-vm-modules jest --silent --runInBand --forceExit"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.4",
    "@medusajs/admin-sdk": "2.8.4",
    "@medusajs/cli": "2.8.4",
    "@medusajs/framework": "2.8.4",
    "@medusajs/icons": "2.8.4",
    "@medusajs/medusa": "2.8.4",
    "@medusajs/test-utils": "^2.8.4",
    "@medusajs/ui": "4.0.14",
    "@mikro-orm/cli": "6.4.9",
    "@mikro-orm/core": "6.4.9",
    "@mikro-orm/knex": "6.4.9",
    "@mikro-orm/migrations": "6.4.9",
    "@mikro-orm/postgresql": "6.4.9",
    "@swc/core": "1.5.7",
    "@swc/jest": "^0.2.37",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.2",
    "@types/react-dom": "^18.2.25",
    "awilix": "^8.0.1",
    "jest": "^29.7.0",
    "pg": "^8.13.0",
    "prop-types": "^15.8.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.2",
    "vite": "^5.2.11",
    "yalc": "^1.0.0-pre.53"
  },
  "peerDependencies": {
    "@medusajs/admin-sdk": "2.8.4",
    "@medusajs/cli": "2.8.4",
    "@medusajs/framework": "2.8.4",
    "@medusajs/icons": "2.8.4",
    "@medusajs/medusa": "2.8.4",
    "@medusajs/test-utils": "2.8.4",
    "@medusajs/ui": "4.0.14"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "yarn@4.6.0"
}
